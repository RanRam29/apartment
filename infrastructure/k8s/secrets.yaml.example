# Copy to secrets.yaml, fill in values, then:
# kubectl apply -f secrets.yaml
# NEVER commit the real secrets.yaml to git
apiVersion: v1
kind: Secret
metadata:
  name: dirapp-secrets
  namespace: dirapp
type: Opaque
stringData:
  POSTGRES_USER: apartment_user
  POSTGRES_PASSWORD: CHANGE_ME
  MONGO_URI: mongodb://mongo_user:CHANGE_ME@mongodb:27017/apartment_preferences?authSource=admin
  REDIS_PASSWORD: CHANGE_ME
  JWT_SECRET: CHANGE_ME_long_random_string
  GEMINI_API_KEY: CHANGE_ME
  CLOUDINARY_CLOUD_NAME: CHANGE_ME
  CLOUDINARY_UPLOAD_PRESET: CHANGE_ME
  MESHULAM_API_KEY: CHANGE_ME
