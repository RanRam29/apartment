{
  "expo": {
    "name": "DirApp",
    "slug": "dirapp",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBFAFA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dirapp.rental",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow DirApp to access your photos to upload apartment images.",
        "NSCameraUsageDescription": "Allow DirApp to use your camera to take apartment photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBFAFA"
      },
      "package": "com.dirapp.rental",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow DirApp to access your photos to upload apartment images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00E5FF",
          "androidMode": "default",
          "androidCollapsedTitle": "DirApp"
        }
      ],
      "expo-video"
    ],
    "scheme": "dirapp",
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/3573e171-6f0f-4a4a-9d02-e75e65602f33"
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "3573e171-6f0f-4a4a-9d02-e75e65602f33"
      }
    }
  }
}
