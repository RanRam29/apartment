# Single backend for this client — use ONE Render (or other) URL for production everywhere
# (Vercel, EAS, preview/staging). Origin only: no trailing slash, no /api suffix (the app adds /api).
#
# Leave unset for local dev → defaults to http://localhost:3000 (see src/services/apiConfig.ts).
# EXPO_PUBLIC_API_URL=https://YOUR-SERVICE.onrender.com
