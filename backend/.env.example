NODE_ENV=production
PORT=10000

# ── Render / free-tier deployment ────────────────────────────────────────────
# Set these three and leave the individual host/port vars unset.

# PostgreSQL — Neon connection string (Settings → Connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# MongoDB — Atlas connection string (Connect → Drivers)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/apartment_preferences?retryWrites=true&w=majority

# Redis — Upstash ioredis URL (Database → Connect → ioredis)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ── Local / Docker Compose / Kubernetes ──────────────────────────────────────
# Used only when DATABASE_URL / REDIS_URL are NOT set.
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=apartment_db
# POSTGRES_USER=apartment_user
# POSTGRES_PASSWORD=apartment_pass
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=redis_pass

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Gemini AI (free tier) ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── AI microservice ──────────────────────────────────────────────────────────
AI_SERVICE_URL=https://your-ai-service.onrender.com

# ── Payments (Meshulam) ──────────────────────────────────────────────────────
MESHULAM_API_KEY=your_meshulam_api_key

# ── Kafka (optional — server starts without it) ───────────────────────────────
# KAFKA_BROKERS=kafka:9092
