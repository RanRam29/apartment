NODE_ENV=development
PORT=3000

# PostgreSQL — use DATABASE_URL for hosted Postgres (Render, Neon, Supabase)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=apartment_db
POSTGRES_USER=apartment_user
POSTGRES_PASSWORD=apartment_pass

# MongoDB
MONGO_URI=mongodb://mongo_user:mongo_pass@mongodb:27017/apartment_preferences?authSource=admin

# Redis — use REDIS_URL for Upstash/hosted Redis, or REDIS_HOST+PORT for local/K8s
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# JWT — required for login (>=20 chars). On Render: Dashboard → Environment → JWT_SECRET
# (use Generate or `openssl rand -base64 32`). Wrong/missing secret → HTTP 503 on /api/auth/login.
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS — merge CLIENT_ORIGIN and CLIENT_ORIGINS (each comma-separated). Both are combined.
# Production example (Render): CLIENT_ORIGINS=https://apartment-olive.vercel.app,http://localhost:8081
# On Render (RENDER=true) + NODE_ENV=production, https://apartment-olive.vercel.app is allowed automatically for this repo.
# Or allow every *.vercel.app host (previews + prod aliases): CORS_ALLOW_VERCEL_PREVIEWS=true
CLIENT_ORIGIN=http://localhost:3000
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Kafka (optional — leave unset on Render to avoid connecting to localhost)
# KAFKA_ENABLED=false
# KAFKA_BROKERS=kafka:9092

# Cloudinary (image uploads - legacy)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Cloudflare R2 Storage & API Credentials
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CF_API_TOKEN=your_cloudflare_api_token

# Webhook signature secret (Render auto-generates; set manually elsewhere)
WEBHOOK_SECRET=

# Israeli Payment Gateways
BIT_API_KEY=
PAYBOX_API_KEY=
MESHULAM_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Gemini AI (free tier: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# Model id (default: gemini-flash-latest). Override only if Google deprecates the alias.
# GEMINI_MODEL=gemini-flash-latest

# Optional limits for Gemini-backed routes (POST /recommendations/search, POST .../marketing-copy).
# In NODE_ENV=test limits are relaxed unless GEMINI_RATE_LIMIT_IN_TESTS=1.
# GEMINI_SEARCH_RATE_MAX=60
# GEMINI_SEARCH_RATE_WINDOW_MS=900000
# GEMINI_MARKETING_RATE_MAX=40
# GEMINI_MARKETING_RATE_WINDOW_MS=900000

# AI Service (optional microservice — see Info/ADR_AI_Service_Strategy.md)
# When set, backend proxies numeric scoring (/api/leads/score, /api/recommendations/score) with Node fallback.
AI_SERVICE_URL=http://ai-service:8000
# AI_SERVICE_TIMEOUT_MS=8000
